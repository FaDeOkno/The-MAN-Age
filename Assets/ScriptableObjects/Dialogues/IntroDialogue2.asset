  m_Script: {fileID: 11500000, guid: 14be3b72f7959204c9ba65aa28ce6fa0, type: 3}
  m_Name: IntroDialogue2
  m_EditorClassIdentifier: Assembly-CSharp::DialogueList
  Dialogue:
  - DialogueText: Hello. You're doing pretty well as I see. At least, better than
      the others.
    TypingSpeed: 0.02
    StartColor: {r: 0, g: 0, b: 0, a: 0}
    EndColor: {r: 0.8207547, g: 0.8207547, b: 0.8207547, a: 1}
    ColorCurve:
      serializedVersion: 2
      m_Curve:
      - serializedVersion: 3
        time: 0
        value: 0
        inSlope: 2
        outSlope: 2
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      - serializedVersion: 3
        time: 1
        value: 1
        inSlope: 0
        outSlope: 0
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      m_PreInfinity: 2
      m_PostInfinity: 2
      m_RotationOrder: 4
  - DialogueText: There was an incident yesterday, and because of it only several
      visitors came here.
    TypingSpeed: 0.02
    StartColor: {r: 0, g: 0, b: 0, a: 0}
    EndColor: {r: 0.8207547, g: 0.8207547, b: 0.8207547, a: 1}
    ColorCurve:
      serializedVersion: 2
      m_Curve:
      - serializedVersion: 3
        time: 0
        value: 0
        inSlope: 2
        outSlope: 2
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      - serializedVersion: 3
        time: 1
        value: 1
        inSlope: 0
        outSlope: 0
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      m_PreInfinity: 2
      m_PostInfinity: 2
      m_RotationOrder: 4
  - DialogueText: Speaking of incidents, did you see the news? That crazy dwarf escaped
      again.
    TypingSpeed: 0.02
    StartColor: {r: 0, g: 0, b: 0, a: 0}
    EndColor: {r: 0.8207547, g: 0.8207547, b: 0.8207547, a: 1}
    ColorCurve:
      serializedVersion: 2
      m_Curve:
      - serializedVersion: 3
        time: 0
        value: 0
        inSlope: 2
        outSlope: 2
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      - serializedVersion: 3
        time: 1
        value: 1
        inSlope: 0
        outSlope: 0
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      m_PreInfinity: 2
      m_PostInfinity: 2
      m_RotationOrder: 4
  - DialogueText: Don't worry, that's none of our business. Just make sure that everyone
      that enters match our only rule.
    TypingSpeed: 0.02
    StartColor: {r: 0, g: 0, b: 0, a: 0}
    EndColor: {r: 0.8207547, g: 0.8207547, b: 0.8207547, a: 1}
    ColorCurve:
      serializedVersion: 2
      m_Curve:
      - serializedVersion: 3
        time: 0
        value: 0
        inSlope: 2
        outSlope: 2
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      - serializedVersion: 3
        time: 1
        value: 1
        inSlope: 0
        outSlope: 0
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      m_PreInfinity: 2
      m_PostInfinity: 2
      m_RotationOrder: 4
  - DialogueText: Dwarves have a different life span, so you should know that their
      MAN age starts at 80 years.
    TypingSpeed: 0.02
    StartColor: {r: 0, g: 0, b: 0, a: 0}
    EndColor: {r: 0.8207547, g: 0.8207547, b: 0.8207547, a: 1}
    ColorCurve:
      serializedVersion: 2
      m_Curve:
      - serializedVersion: 3
        time: 0
        value: 0
        inSlope: 2
        outSlope: 2
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      - serializedVersion: 3
        time: 1
        value: 1
        inSlope: 0
        outSlope: 0
        tangentMode: 0
        weightedMode: 0
        inWeight: 0
        outWeight: 0
      m_PreInfinity: 2
      m_PostInfinity: 2
      m_RotationOrder: 4
  - DialogueText: Good luck with these little alcoholics.
    TypingSpeed: 0.02
    StartColor: {r: 0, g: 0, b: 0, a: 0}
    EndColor: {r: 0.8207547, g: 0.8207547, b: 0.8207547, a: 1}
